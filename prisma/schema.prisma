// =============================================================================
// School management
// =============================================================================

model School {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  logoUrl      String?  @map("logo_url")
  website      String?
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  address      String?
  city         String?
  country      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  admins             SchoolAdmin[]
  classes            ClassRoom[]
  teacherAssignments TeacherAssignment[]

  @@map("school")
}

model SchoolAdmin {
  id            String      @id @default(uuid())
  schoolId      String      @map("school_id")
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userProfileId String      @map("user_profile_id")
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  isPrimary     Boolean     @default(false) @map("is_primary")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([schoolId], map: "school_admin_schoolId_idx")
  @@index([userProfileId], map: "school_admin_userProfileId_idx")
  @@map("school_admin")
}

model ClassRoom {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String
  code         String?  @unique
  description  String?
  academicYear String?  @map("academic_year")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members            ClassMember[]
  teacherAssignments TeacherAssignment[]

  @@index([schoolId], map: "class_schoolId_idx")
  @@index([code], map: "class_code_idx")
  @@map("class")
}

model ClassMember {
  id            String     @id @default(uuid())
  classRoomId   String     @map("class_id")
  classRoom     ClassRoom  @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  userProfileId String     @map("user_profile_id")
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  joinedAt      DateTime   @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt        DateTime?  @map("left_at") @db.Timestamptz(6)
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([classRoomId], map: "class_member_classId_idx")
  @@index([userProfileId], map: "class_member_userProfileId_idx")
  @@map("class_member")
}

model TeacherAssignment {
  id           String      @id @default(uuid())
  teacherId    String      @map("teacher_id")
  teacher      UserProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classRoomId  String?     @map("class_id")
  classRoom    ClassRoom?  @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  schoolId     String?     @map("school_id")
  school       School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignedAt   DateTime    @default(now()) @map("assigned_at") @db.Timestamptz(6)
  unassignedAt DateTime?   @map("unassigned_at") @db.Timestamptz(6)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([teacherId], map: "teacher_assignment_teacherId_idx")
  @@index([classRoomId], map: "teacher_assignment_classId_idx")
  @@index([schoolId], map: "teacher_assignment_schoolId_idx")
  @@map("teacher_assignment")
}
