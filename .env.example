# ======================================================
# 🌍 Application
# ======================================================

# Public base URL of the app (used on client & server)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL used internally by Better Auth
BETTER_AUTH_URL=http://localhost:3000


# ======================================================
# 🔐 Authentication & Security
# ======================================================

# Secret used to sign sessions, JWTs, and auth tokens
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=


# ======================================================
# 🗄️ Database
# ======================================================

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=


# ======================================================
# 📧 Email (Resend)
# ======================================================
RESEND_API_KEY=
RESEND_FROM=no-reply@itlearn.be


# ======================================================
# 🔑 OAuth Providers
# ======================================================

# ---- Discord ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- GitHub ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ======================================================
# 🧪 Runtime Environment
# ======================================================

# development | production | test
NODE_ENV=development


# ======================================================
# 💳 Stripe Payment Integration
# ======================================================

# Stripe API Keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook Secret (for webhook signature verification)
# Get from Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for subscription plans
# Create these in Stripe Dashboard -> Products
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_LIFETIME=
