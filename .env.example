DISCORD_CLIENT_SECRET=

# --- GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


